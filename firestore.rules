rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users
    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Coffee Shops
    match /coffeeShops/{shopId} {
      allow read: if true;
      allow write: if request.auth != null; // Ideally restricted further or handled via Cloud Functions
    }
    
    // Wi-Fi Passwords
    match /wifiPasswords/{passwordId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null; // Mostly handled via transactions in service
    }
    
    // Votes
    match /votes/{voteId} {
      allow read: if true;
      allow create: if request.auth != null;
    }
    
    // Favorites
    match /favorites/{favoriteId} {
      allow read, write: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
    }
    
    // Reports
    match /reports/{reportId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null;
    }
  }
}
