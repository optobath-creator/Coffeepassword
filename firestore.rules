rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // allow anyone to read and write to all collections
    // NOTE: In a real production app with high traffic, we would add rate limiting 
    // and validation here. For launch, we are prioritizing frictionless access.
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
